rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- PLAYERS & GAME HISTORY ---
    match /players/{userId}/{documents=**} {
      allow read, write: if isOwner(userId);
    }

    // --- DAILY CHALLENGE LEADERBOARD ---
    match /leaderboards/dailyChallenge {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
                      request.resource.data.date is string &&
                      request.resource.data.topScores is list &&
                      request.resource.data.topScores.size() <= 10 &&
                      (request.resource.data.topScores.size() == 0 ||
                        ( 'userID' in request.resource.data.topScores[0] &&
                          'name' in request.resource.data.topScores[0] &&
                          'score' in request.resource.data.topScores[0] &&
                          'wordsFound' in request.resource.data.topScores[0] &&
                          'totalWords' in request.resource.data.topScores[0] &&
                          request.resource.data.topScores[0].score is number &&
                          request.resource.data.topScores[0].wordsFound is number &&
                          request.resource.data.topScores[0].totalWords is number)
                      );
    }

    // --- LEADERBOARDS (ALL-TIME & TIMED DAILY) ---
    match /leaderboards/{boardId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (
            (boardId == 'daily' &&
                request.resource.data.topByHighScore is list &&
                request.resource.data.topByTotalScore is list &&
                request.resource.data.topByBestWord is list
            ) ||
            (boardId == 'allTime' &&
                request.resource.data.topByHighScore is list &&
                request.resource.data.topByTotalPoints is list &&
                request.resource.data.topByBestWord is list
            )
        );
    }

    // --- Daily Puzzles (Generated by Cloud Function) ---
    match /dailyPuzzles/{puzzleId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- GLOBAL GAME STATS ---
    match /gameStats/stats {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
                        request.resource.data.playCount == resource.data.playCount + 1;
    }

    // --- CHALLENGES (Friend challenge boards) ---
    match /challenges/{challengeId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
