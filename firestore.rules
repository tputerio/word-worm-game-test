rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- PLAYERS & GAME HISTORY ---
    match /players/{userId}/{documents=**} {
      allow read, write: if isOwner(userId);
    }

    // --- DAILY CHALLENGE LEADERBOARD ---
    match /leaderboards/dailyChallenge {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
                      request.resource.data.date is string &&
                      request.resource.data.topScores is list &&
                      request.resource.data.topScores.size() <= 10 &&
                      (request.resource.data.topScores.size() == 0 ||
                        ( 'userID' in request.resource.data.topScores[0] &&
                          'name' in request.resource.data.topScores[0] &&
                          'score' in request.resource.data.topScores[0] &&
                          'wordsFound' in request.resource.data.topScores[0] &&
                          'totalWords' in request.resource.data.topScores[0] &&
                          request.resource.data.topScores[0].score is number &&
                          request.resource.data.topScores[0].wordsFound is number &&
                          request.resource.data.topScores[0].totalWords is number)
                      );
    }

    // --- LEADERBOARDS (ALL-TIME & TIMED DAILY) ---
    match /leaderboards/{boardId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (
            (boardId == 'daily' &&
                request.resource.data.topByHighScore is list &&
                request.resource.data.topByTotalScore is list &&
                request.resource.data.topByBestWord is list
            ) ||
            (boardId == 'allTime' &&
                request.resource.data.topByHighScore is list &&
                request.resource.data.topByTotalPoints is list &&
                request.resource.data.topByBestWord is list
            )
        );
    }

    // --- DAILY SCORES (per-player best score of the day, used to compute
    // rank/percentile for everyone, not just the top 10 kept on leaderboards/daily) ---
    match /dailyScores/{date}/entries/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId) &&
                      request.resource.data.keys().hasOnly(['score']) &&
                      request.resource.data.score is number;
    }

    // --- Daily Puzzles (Generated by Cloud Function) ---
    match /dailyPuzzles/{puzzleId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- GLOBAL GAME STATS ---
    match /gameStats/stats {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
                        request.resource.data.playCount == resource.data.playCount + 1;
    }

    // --- CHALLENGES (Friend challenge boards) ---
    match /challenges/{challengeId} {
      // Only your own entry in the results map may be added or changed.
      function onlyOwnResultsChange() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['results']) &&
               request.resource.data.results.diff(resource.data.get('results', {})).affectedKeys().hasOnly([request.auth.uid]);
      }
      // Joining via link: the only allowed participants change is adding
      // your own uid — nothing else touched, nobody removed.
      function onlyAddsSelfToParticipants() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']) &&
               request.resource.data.participants is list &&
               request.resource.data.participants.toSet().difference(resource.data.get('participants', []).toSet()).hasOnly([request.auth.uid]) &&
               resource.data.get('participants', []).toSet().difference(request.resource.data.participants.toSet()).size() == 0;
      }
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      // `get` stays open to any signed-in player: a challenge link must load
      // for an invitee who isn't a participant yet. `list` is restricted so
      // the collection can't be enumerated/scraped wholesale — every query the
      // client runs only returns challenges the caller is involved in
      // (participants array-contains, createdBy ==, or toUid == their uid),
      // and the rule requires each returned doc to satisfy one of those.
      allow get:  if isSignedIn();
      allow list: if isSignedIn() && (
        request.auth.uid in resource.data.get('participants', []) ||
        resource.data.get('createdBy', '') == request.auth.uid ||
        resource.data.get('toUid', '') == request.auth.uid
      );
      allow update: if isSignedIn() && (onlyOwnResultsChange() || onlyAddsSelfToParticipants());
      // Creators may revoke (delete) their own challenges.
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // --- USERNAMES (unique username registry: usernames/{lowercased} -> uid) ---
    match /usernames/{name} {
      allow get: if isSignedIn();
      // Create only succeeds if the doc doesn't exist yet — first come, first served.
      allow create: if isSignedIn() &&
                       request.resource.data.uid == request.auth.uid &&
                       name.matches('[a-z0-9_-]{2,15}');
      allow update: if isSignedIn() &&
                       resource.data.uid == request.auth.uid &&
                       request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
